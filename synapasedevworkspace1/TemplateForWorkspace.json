		{
			"name": "[concat(parameters('workspaceName'), '/SQL script 1')]",
			"type": "Microsoft.Synapse/workspaces/sqlscripts",
			"apiVersion": "2019-06-01-preview",
			"properties": {
				"content": {
					"query": "SELECT * FROM OPENROWSET(\n    BULK        'dim_customer',\n    DATA_SOURCE = 'gold_storage',\n    FORMAT      = 'DELTA'\n) AS r;\nGO\n\nSELECT * FROM OPENROWSET(\n    BULK        'dim_product',\n    DATA_SOURCE = 'gold_storage',\n    FORMAT      = 'DELTA'\n) AS r;\nGO\n\nSELECT * FROM OPENROWSET(\n    BULK        'dim_date',\n    DATA_SOURCE = 'gold_storage',\n    FORMAT      = 'DELTA'\n) AS r;\nGO\n\nSELECT * FROM OPENROWSET(\n    BULK        'fact_sales',\n    DATA_SOURCE = 'gold_storage',\n    FORMAT      = 'DELTA'\n) AS r;\nGO\n\n\nSELECT * FROM OPENROWSET(\n    BULK        'fact_marketing',\n    DATA_SOURCE = 'gold_storage',\n    FORMAT      = 'DELTA'\n) AS r;\nGO\n\n-- Verify\nSELECT TABLE_SCHEMA, TABLE_NAME\nFROM   INFORMATION_SCHEMA.TABLES\nWHERE  TABLE_SCHEMA = 'salesDW'\nORDER  BY TABLE_NAME;\nGO",
					"metadata": {
						"language": "sql"
					},
					"currentConnection": {
						"databaseName": "gold_saleslt",
						"poolName": "Built-in"
					},
					"resultLimit": 5000
				},
				"type": "SqlQuery"
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('workspaceName'), '/SQL script 2')]",
			"type": "Microsoft.Synapse/workspaces/sqlscripts",
			"apiVersion": "2019-06-01-preview",
			"properties": {
				"content": {
					"query": "USE gold_saleslt;\nGO\n\n-- Recreate credential in this database\nCREATE MASTER KEY ENCRYPTION BY PASSWORD = 'YourStrongPassword123!';\nGO\n\nCREATE DATABASE SCOPED CREDENTIAL gold_credential\nWITH IDENTITY = 'Managed Identity';\nGO\n\nCREATE EXTERNAL DATA SOURCE gold_storage\nWITH (\n    LOCATION   = 'https://storageproject12026.dfs.core.windows.net/gold/saleslt',\n    CREDENTIAL = gold_credential\n);\nGO\n",
					"metadata": {
						"language": "sql"
					},
					"currentConnection": {
						"databaseName": "gold_saleslt",
						"poolName": "Built-in"
					},
					"resultLimit": 5000
				},
				"type": "SqlQuery"
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('workspaceName'), '/SQL script 3')]",
			"type": "Microsoft.Synapse/workspaces/sqlscripts",
			"apiVersion": "2019-06-01-preview",
			"properties": {
				"content": {
					"query": "CREATE USER [superromelus_gmail.com#EXT#@superromelusgmail.onmicrosoft.com]\nFROM EXTERNAL PROVIDER;\n\nALTER ROLE db_datareader\nADD MEMBER [superromelus_gmail.com#EXT#@superromelusgmail.onmicrosoft.com];\n\nUSE gold_saleslt;\nGO\n\n-- Drop existing if any\nDROP DATABASE SCOPED CREDENTIAL [https://storageproject12026.dfs.core.windows.net];\nGO\n\n-- Recreate with User Identity instead of Managed Identity\nCREATE DATABASE SCOPED CREDENTIAL [https://storageproject12026.dfs.core.windows.net]\nWITH IDENTITY = 'User Identity';\nGO\n\n-- Grant to public\nGRANT REFERENCES ON DATABASE SCOPED CREDENTIAL::[https://storageproject12026.dfs.core.windows.net]\nTO [public];\nGO\n\n-- Test immediately\nSELECT TOP 5 * FROM salesDW.dim_customer;\nGO",
					"metadata": {
						"language": "sql"
					},
					"currentConnection": {
						"databaseName": "gold_saleslt",
						"poolName": "Built-in"
					},
					"resultLimit": 5000
